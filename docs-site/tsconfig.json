{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ESNext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/.source": [
        "./.source/index.ts"
      ],
      "@/vendor/repo-planner": ["./types/repo-planner.d.ts"],
      "@/vendor/repo-planner/api/planning-cli/run/route": ["./types/repo-planner.d.ts"],
      "@/vendor/repo-planner/api/planning-state/route": ["./types/repo-planner.d.ts"],
      "@/vendor/repo-planner/api/planning-metrics/route": ["./types/repo-planner.d.ts"],
      "@/vendor/repo-planner/api/planning-reports/latest/route": ["./types/repo-planner.d.ts"],
      "@/vendor/repo-planner/api/planning-edits/apply/route": ["./types/repo-planner.d.ts"],
      "@/vendor/repo-planner/api/test-reports/unit/route": ["./types/repo-planner.d.ts"],
      "@/*": [
        "./*"
      ],
      "@payload-config": [
        "./payload.config.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../vendor/repo-planner"
  ]
}
