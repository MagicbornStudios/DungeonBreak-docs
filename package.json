{
  "name": "dungeonbreak",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "description": "DungeonBreak – linear world, branching narrative RPG",
  "bin": {
    "planning": "vendor/repo-planner/scripts/loop-cli.mjs"
  },
  "scripts": {
    "planning": "node vendor/repo-planner/scripts/loop-cli.mjs",
    "lab:install": "node scripts/lab-install.mjs",
    "lab": "node scripts/lab-run.mjs",
    "dev": "npx concurrently -n docs,kaplay -c blue,green \"pnpm --dir docs-site run dev\" \"pnpm --dir packages/kaplay-demo run dev\"",
    "game:standalone": "pnpm --dir packages/kaplay-demo run dev:standalone",
    "docs:generate": "node scripts/docs-generate-mdx.mjs",
    "docs:serve": "node scripts/docs-serve.mjs",
    "docs:dev": "pnpm --dir docs-site run migrate && pnpm --dir docs-site run dev",
    "mcp:game": "pnpm --dir packages/engine-mcp run dev",
    "agent:play": "pnpm --dir packages/engine-mcp run agent:play",
    "mcp:install": "node scripts/install-mcp-config.mjs --target all",
    "mcp:install:dry-run": "node scripts/install-mcp-config.mjs --target all --dry-run",
    "mcp:planning": "pnpm --dir packages/planning-mcp run dev",
    "payload:sync-game-data": "node scripts/payload-sync-game-data.mjs",
    "engine:build": "pnpm --dir packages/engine run build",
    "engine:typecheck": "pnpm --dir packages/engine run typecheck",
    "docs:test": "pnpm --dir docs-site run typecheck && pnpm --dir docs-site run test:unit && pnpm --dir docs-site run test:e2e",
    "planning:test": "node --test scripts/loop-cli.test.mjs",
    "ralph": "node scripts/ralph-loop.mjs",
    "env:bundle:seal": "node scripts/env-bundle.mjs seal",
    "env:bundle:unseal": "node scripts/env-bundle.mjs unseal"
  },
  "devDependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.3",
    "ejs": "^4.0.1",
    "fast-xml-parser": "^5.4.2"
  },
  "optionalDependencies": {
    "fastembed": "^2.1.0"
  }
}
